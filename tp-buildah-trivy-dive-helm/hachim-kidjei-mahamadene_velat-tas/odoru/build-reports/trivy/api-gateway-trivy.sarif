            {
              "id": "CVE-2026-5598",
              "name": "LanguageSpecificPackageVulnerability",
              "shortDescription": {
                "text": "bouncycastle: BC-JAVA: private key leakage via non-constant time comparisons"
              },
              "fullDescription": {
