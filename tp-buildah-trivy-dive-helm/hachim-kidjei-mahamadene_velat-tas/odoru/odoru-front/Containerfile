FROM docker.io/node:22-alpine AS build

LABEL org.opencontainers.image.title="odoru-front"
LABEL org.opencontainers.image.description="Odoru React frontend"
LABEL org.opencontainers.image.version="1.0.0"

WORKDIR /app

COPY odoru-front/package*.json ./
RUN npm ci

COPY odoru-front/ ./
RUN npm run build

FROM docker.io/nginx:1.27-alpine

COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]