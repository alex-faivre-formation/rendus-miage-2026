FROM docker.io/eclipse-temurin:17-jre-alpine
LABEL org.opencontainers.image.title="odoru-discovery-service"
LABEL org.opencontainers.image.description="Odoru Eureka discovery service"
LABEL org.opencontainers.image.version="1.0.0"

WORKDIR /app

RUN addgroup -S odoru && adduser -S odoru -G odoru

COPY services/discovery-service/target/*.jar app.jar

USER odoru

EXPOSE 8761

ENTRYPOINT ["java", "-jar", "/app/app.jar"]