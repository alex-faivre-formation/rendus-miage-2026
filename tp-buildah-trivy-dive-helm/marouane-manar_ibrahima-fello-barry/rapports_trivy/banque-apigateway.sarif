              "id": "CVE-2025-22228",
              "name": "LanguageSpecificPackageVulnerability",
              "shortDescription": {
                "text": "spring-security-core: Spring Security BCryptPasswordEncoder does not enforce maximum password length"
              },
              "fullDescription": {
